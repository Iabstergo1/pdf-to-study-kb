{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Manifest",
  "description": "小节任务清单",
  "type": "object",
  "properties": {
    "book_id": {
      "type": "string",
      "description": "资料标识"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{3}-\\d{2}$",
            "description": "小节标识，如 SAMPLE-001-01"
          },
          "source_order": {
            "type": "string",
            "description": "原书章节序号，如 1.1"
          },
          "title": {
            "type": "string"
          },
          "source_locator": {
            "type": "object",
            "properties": {
              "pages": {
                "type": "array",
                "items": { "type": "integer" }
              }
            },
            "required": ["pages"]
          },
          "status": {
            "type": "string",
            "enum": [
              "registered",
              "extracted",
              "drafted",
              "reviewed",
              "accepted",
              "published",
              "needs_reextract",
              "needs_formula_review",
              "needs_human_review",
              "rejected"
            ]
          },
          "extraction_risk": {
            "type": "string",
            "enum": ["unknown", "low", "medium", "high"]
          },
          "formula_risk": {
            "type": "string",
            "enum": ["unknown", "low", "medium", "high"]
          },
          "publish_status": {
            "type": "string",
            "enum": ["not-published", "published"]
          }
        },
        "required": ["id", "source_order", "title", "source_locator", "status"]
      }
    }
  },
  "required": ["book_id", "sections"]
}

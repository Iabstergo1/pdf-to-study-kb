{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Semantic Unit Plan",
  "description": "语义单元规划（由 LLM 生成，人工审批后生效）",
  "type": "object",
  "properties": {
    "book_id": {
      "type": "string",
      "description": "资料标识"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "planner_model": {
      "type": "string",
      "description": "用于生成规划的模型"
    },
    "total_pages": {
      "type": "integer",
      "description": "PDF 总页数"
    },
    "coverage_validation": {
      "type": "object",
      "description": "页码覆盖校验结果",
      "properties": {
        "passed": { "type": "boolean" },
        "missing_pages": { "type": "array", "items": { "type": "integer" } },
        "overlaps": { "type": "array", "items": { "type": "object" } },
        "validated_at": { "type": "string", "format": "date-time" }
      }
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "unit_id": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{3}-\\d{2}$",
            "description": "单元标识，如 GTW-001-01"
          },
          "title": {
            "type": "string"
          },
          "unit_type": {
            "type": "string",
            "enum": ["concept", "derivation", "application", "intro", "transition", "appendix"],
            "description": "单元类型"
          },
          "include": {
            "type": "boolean",
            "description": "是否生成讲义。intro/transition 可标记 false"
          },
          "skip_reason": {
            "type": "string",
            "description": "仅当 include=false 时必填"
          },
          "source_scope": {
            "type": "object",
            "properties": {
              "pages": {
                "type": "array",
                "items": { "type": "integer" },
                "description": "覆盖页码列表"
              },
              "headings": {
                "type": "array",
                "items": { "type": "string" },
                "description": "覆盖的原文章节标题"
              }
            },
            "required": ["pages"]
          },
          "extraction_method": {
            "type": "string",
            "enum": ["text", "screenshot_ocr", "hybrid"],
            "description": "推荐的 PDF 内容提取方式"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "依赖的其他 unit_id"
          },
          "risk_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "风险标记，如 formula_heavy, table_dense, scanned_page"
          },
          "formula_risk": {
            "type": "string",
            "enum": ["unknown", "low", "medium", "high"]
          },
          "planner_confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "review_status": {
            "type": "string",
            "enum": ["pending", "accepted", "edited", "skipped"],
            "description": "人工审批状态"
          },
          "overlap_reason": {
            "type": "string",
            "description": "当与其他 unit 页码重叠时必须说明原因"
          },
          "output_targets": {
            "type": "array",
            "items": { "type": "string" },
            "description": "输出产物类型，如 [section-lesson, concept-card, glossary-entry]"
          },
          "merge_from": {
            "type": "array",
            "items": { "type": "string" },
            "description": "合并来源的 unit_id 列表"
          }
        },
        "required": ["unit_id", "title", "unit_type", "include", "source_scope", "extraction_method", "formula_risk", "planner_confidence", "review_status"]
      }
    }
  },
  "required": ["book_id", "generated_at", "total_pages", "units"]
}

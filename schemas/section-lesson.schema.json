{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Lesson",
  "description": "单元学习讲义",
  "type": "object",
  "properties": {
    "frontmatter": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "unit_id" },
        "type": { "type": "string", "const": "section-lesson" },
        "source_title": { "type": "string" },
        "source_locator": {
          "type": "object",
          "properties": {
            "pages": { "type": "array", "items": { "type": "integer" } },
            "headings": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["pages"]
        },
        "book_order": { "type": "string", "description": "章节序号，如 2.3" },
        "chapter": { "type": "string", "description": "所属章节" },
        "importance": { "type": "string", "enum": ["A", "B", "C"] },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "formula_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "accepted"] },
        "generation_stage": { "type": "string", "enum": ["draft", "reviewed", "published"] },
        "status": { "type": "string", "enum": ["draft", "reviewed", "published"], "description": "Dataview 用状态字段" },
        "concepts": { "type": "array", "items": { "type": "string" }, "description": "本 unit 涉及的核心概念" },
        "symbols": { "type": "array", "items": { "type": "string" }, "description": "本 unit 涉及的符号" },
        "depends_on": { "type": "array", "items": { "type": "string" }, "description": "依赖的 unit_id" },
        "source_pdf": { "type": "string", "description": "来源 PDF 文件名" },
        "source_pages": { "type": "array", "items": { "type": "integer" }, "description": "来源页码（与 source_locator.pages 一致）" },
        "risk_flags": { "type": "array", "items": { "type": "string" }, "description": "风险标记" },
        "managed_by": { "type": "string", "const": "pipeline", "description": "标识为流水线管理文件" }
      },
      "required": ["id", "type", "source_title", "source_locator", "book_order", "chapter", "importance", "difficulty", "formula_risk", "review_status", "status", "managed_by"]
    },
    "sections": {
      "type": "object",
      "properties": {
        "learning_position": { "type": "string" },
        "core_takeaways": { "type": "string" },
        "must_master": { "type": "string" },
        "first_pass_skippable": { "type": "string" },
        "core_concepts": { "type": "string" },
        "model_structure": { "type": "string" },
        "intuitive_explanation": { "type": "string" },
        "misunderstandings": { "type": "string" },
        "knowledge_bridge_candidates": { "type": "string" },
        "self_test_questions": { "type": "string" },
        "when_to_return_source": { "type": "string" },
        "source_locator": { "type": "string" }
      },
      "required": ["learning_position", "core_takeaways", "must_master", "core_concepts"]
    }
  },
  "required": ["frontmatter", "sections"]
}

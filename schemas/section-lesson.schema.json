{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Lesson",
  "description": "小节学习讲义",
  "type": "object",
  "properties": {
    "frontmatter": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "const": "section-lesson" },
        "source_title": { "type": "string" },
        "source_locator": {
          "type": "object",
          "properties": {
            "pages": { "type": "array", "items": { "type": "integer" } }
          },
          "required": ["pages"]
        },
        "book_order": { "type": "string" },
        "importance": { "type": "string", "enum": ["A", "B", "C"] },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "personal_kb_relevance": { "type": "string", "enum": ["high", "medium", "low"] },
        "formula_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "accepted"] },
        "generation_stage": { "type": "string", "enum": ["draft", "reviewed", "published"] }
      },
      "required": ["id", "type", "source_title", "source_locator", "book_order", "importance", "difficulty", "review_status"]
    },
    "sections": {
      "type": "object",
      "properties": {
        "learning_position": { "type": "string" },
        "core_takeaways": { "type": "string" },
        "must_master": { "type": "string" },
        "first_pass_skippable": { "type": "string" },
        "core_concepts": { "type": "string" },
        "model_structure": { "type": "string" },
        "intuitive_explanation": { "type": "string" },
        "misunderstandings": { "type": "string" },
        "knowledge_bridge_candidates": { "type": "string" },
        "self_test_questions": { "type": "string" },
        "when_to_return_source": { "type": "string" },
        "source_locator": { "type": "string" }
      },
      "required": ["learning_position", "core_takeaways", "must_master", "core_concepts"]
    }
  },
  "required": ["frontmatter", "sections"]
}

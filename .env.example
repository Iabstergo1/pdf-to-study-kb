# LLM Provider（DeepSeek V4 系列）
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_REVISE_MODEL=deepseek-v4-pro
LLM_REVIEW_MODEL=deepseek-v4-flash
# 规划是一次性的全局决策，用 Pro 做更细致的语义切分判断，减少人工修正量
LLM_PLANNER_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.3
# Pro 模型生成整本规划/长讲义时非流式响应较慢，给足读超时（秒）
LLM_TIMEOUT_SECONDS=600
# 瞬时错误（超时/连接抖动/429/5xx）自动重试次数，指数退避；4xx 不重试
LLM_MAX_RETRIES=2
LLM_SSL_VERIFY=true

# run-book 并发执行的 unit 数（1=完全串行，rolling memory 质量最高；默认 3）
# 注意：高公式书多数 unit 走本地 OCR（GPU 单资源），并发主要加速 LLM 部分
RUN_BOOK_CONCURRENCY=3

# OCR Provider（surya-ocr，本地运行）
OCR_PROVIDER=surya

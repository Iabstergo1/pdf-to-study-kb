# OpenAI-compatible LLM provider config.
# Copy this file to .env and fill local secrets. Do not commit .env.

LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com

# Default author/revise model.
LLM_MODEL=deepseek-v4-flash

# Stronger review model. Can be the same as LLM_MODEL.
LLM_REVIEW_MODEL=deepseek-v4-pro

# Planner model for plan-sections --planner hybrid-llm.
LLM_PLANNER_MODEL=deepseek-v4-flash

LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120

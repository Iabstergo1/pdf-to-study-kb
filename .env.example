# PDF to Study KB - 环境配置
# 复制此文件为 .env 并填入你的配置

# LLM Provider（DeepSeek V4 系列）
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_REVIEW_MODEL=deepseek-v4-flash
LLM_PLANNER_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=120
LLM_SSL_VERIFY=true

# OCR Provider（surya-ocr，本地运行，支持中文 + LaTeX 公式）
# requirements.txt 默认包含 surya-ocr>=0.20.0；未安装或推理后端不可用时高公式页进入 Review-Queue 人工处理
# 无需额外配置，首次运行会自动下载模型
# Surya 2 OCR 需要 vllm（GPU）或 llama.cpp llama-server（CPU/Apple Silicon）推理后端
OCR_PROVIDER=surya

# 成本控制（可选）
# MAX_UNIT_INPUT_TOKENS=50000
# MAX_UNIT_OUTPUT_TOKENS=10000
# MAX_BOOK_TOKENS=2000000
# MAX_BOOK_COST=50.0

# Memory 配置（可选）
# MEMORY_COMPACT_CHAR_LIMIT=20000
# MAX_REVISE_ATTEMPTS=3

# 测试用 Fake Provider
# LLM_PROVIDER=fake
# LLM_FAKE_RESPONSES_JSON=path/to/fake_responses.json
